{
  "name": "bender-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Real-time viewer for ai-bender sessions. Reads .bender/sessions/<id>/ and streams events via SSE.",
  "scripts": {
    "dev": "bun run src/server/index.ts",
    "start": "NODE_ENV=production bun run src/server/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "preact": "^10.22.1",
    "preact-iso": "^2.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.3"
  }
}
